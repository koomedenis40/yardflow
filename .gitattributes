# Normalise all text files to LF in the repo; leave working tree as-is on Windows
* text=auto eol=lf

# Explicitly binary — never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.pdf binary
*.zip binary
*.gz binary
