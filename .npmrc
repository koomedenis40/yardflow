# Flat node_modules layout.
# Required on Windows for React Native / Expo native (C++/CMake) builds:
# pnpm's default nested .pnpm/<long-hash>/node_modules/ store pushes native
# build paths past the Windows 260-char CreateProcess limit, which breaks
# prefab/CMake (react-native-worklets, react-native-screens, etc.).
# Hoisted is also Expo's recommended layout for pnpm (Metro/autolinking).
node-linker=hoisted
