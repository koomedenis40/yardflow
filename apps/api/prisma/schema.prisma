generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  trial
  active
  past_due
  suspended
  cancelled
}

enum UserTenantRole {
  owner
  cashier
}

enum PaymentStatus {
  unpaid
  partial
  paid
}

enum CorrectableType {
  PURCHASE
  SALE
}

enum StockMovementType {
  PURCHASE
  SALE
  PURCHASE_CORRECTION
  SALE_CORRECTION
  STOCK_ADJUSTMENT
}

model Tenant {
  id            String       @id @default(uuid()) @db.Uuid
  name          String
  slug          String       @unique
  status        TenantStatus @default(trial)
  timezone      String       @default("Africa/Nairobi")
  currency      String       @default("KES")
  receiptPrefix String       @map("receipt_prefix")
  settings      Json         @default("{}")
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  userTenants UserTenant[]
  categories  ScrapCategory[]
  auditLogs   AuditLog[]
  suppliers   Supplier[]
  buyers      Buyer[]
  purchases   Purchase[]
  sales       Sale[]
  stockBalances StockBalance[]
  stockMovements StockMovement[]
  corrections Correction[]
  stockAdjustments StockAdjustment[]
  ledgerEvents LedgerEvent[]

  @@map("tenants")
}

model User {
  id              String   @id @default(uuid()) @db.Uuid
  fullName        String   @map("full_name")
  email           String?  @unique
  phone           String?
  passwordHash    String   @map("password_hash")
  isPlatformAdmin Boolean  @default(false) @map("is_platform_admin")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userTenants   UserTenant[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("users")
}

model UserTenant {
  userId    String         @map("user_id") @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  role      UserTenantRole
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@map("user_tenants")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model ScrapCategory {
  id                       String   @id @default(uuid()) @db.Uuid
  tenantId                 String   @map("tenant_id") @db.Uuid
  yardId                   String?  @map("yard_id") @db.Uuid
  name                     String
  defaultBuyingPricePerKg  Decimal  @default(0) @map("default_buying_price_per_kg") @db.Decimal(14, 2)
  defaultSellingPricePerKg Decimal  @default(0) @map("default_selling_price_per_kg") @db.Decimal(14, 2)
  isActive                 Boolean  @default(true) @map("is_active")
  sortOrder                Int      @default(0) @map("sort_order")
  createdAt                DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases     Purchase[]
  sales         Sale[]
  stockBalances StockBalance[]
  stockMovements StockMovement[]
  stockAdjustments StockAdjustment[]

  @@index([tenantId])
  @@map("scrap_categories")
}

model Supplier {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String
  phone      String?
  notes      String?
  balanceKes Decimal  @default(0) @map("balance_kes") @db.Decimal(14, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases Purchase[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@map("suppliers")
}

model Buyer {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  name       String
  phone      String?
  notes      String?
  balanceKes Decimal  @default(0) @map("balance_kes") @db.Decimal(14, 2)
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales  Sale[]

  @@index([tenantId])
  @@index([tenantId, phone])
  @@map("buyers")
}

model Purchase {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  supplierId        String        @map("supplier_id") @db.Uuid
  categoryId        String        @map("category_id") @db.Uuid
  weightKg          Decimal       @map("weight_kg") @db.Decimal(12, 3)
  pricePerKg        Decimal       @map("price_per_kg") @db.Decimal(14, 2)
  totalValueKes     Decimal       @map("total_value_kes") @db.Decimal(14, 2)
  paymentStatus     PaymentStatus @default(unpaid) @map("payment_status")
  correctionApplied Boolean       @default(false) @map("correction_applied")
  createdBy         String        @map("created_by") @db.Uuid
  idempotencyKey    String        @map("idempotency_key")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier      @relation(fields: [supplierId], references: [id])
  category ScrapCategory @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, supplierId])
  @@map("purchases")
}

model Sale {
  id                String        @id @default(uuid()) @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  buyerId           String        @map("buyer_id") @db.Uuid
  categoryId        String        @map("category_id") @db.Uuid
  weightKg          Decimal       @map("weight_kg") @db.Decimal(12, 3)
  pricePerKg        Decimal       @map("price_per_kg") @db.Decimal(14, 2)
  totalValueKes     Decimal       @map("total_value_kes") @db.Decimal(14, 2)
  costPerKgAtSale   Decimal       @map("cost_per_kg_at_sale") @db.Decimal(14, 2)
  totalCostKes      Decimal       @map("total_cost_kes") @db.Decimal(14, 2)
  grossProfitKes    Decimal       @map("gross_profit_kes") @db.Decimal(14, 2)
  paymentStatus     PaymentStatus @default(unpaid) @map("payment_status")
  correctionApplied Boolean       @default(false) @map("correction_applied")
  createdBy         String        @map("created_by") @db.Uuid
  idempotencyKey    String        @map("idempotency_key")
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  buyer    Buyer         @relation(fields: [buyerId], references: [id])
  category ScrapCategory @relation(fields: [categoryId], references: [id])

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, buyerId])
  @@map("sales")
}

model StockBalance {
  tenantId         String   @map("tenant_id") @db.Uuid
  categoryId       String   @map("category_id") @db.Uuid
  weightKg         Decimal  @default(0) @map("weight_kg") @db.Decimal(12, 3)
  averageCostPerKg Decimal  @default(0) @map("average_cost_per_kg") @db.Decimal(14, 2)
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ScrapCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([tenantId, categoryId])
  @@map("stock_balances")
}

model StockMovement {
  id            String            @id @default(uuid()) @db.Uuid
  tenantId      String            @map("tenant_id") @db.Uuid
  categoryId    String            @map("category_id") @db.Uuid
  movementType  StockMovementType @map("movement_type")
  weightDeltaKg Decimal           @map("weight_delta_kg") @db.Decimal(12, 3)
  valueDeltaKes Decimal           @default(0) @map("value_delta_kes") @db.Decimal(14, 2)
  referenceType String            @map("reference_type")
  referenceId   String            @map("reference_id") @db.Uuid
  createdBy     String            @map("created_by") @db.Uuid
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ScrapCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId, categoryId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("stock_movements")
}

model Correction {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  targetType    CorrectableType @map("target_type")
  targetId      String          @map("target_id") @db.Uuid
  weightDeltaKg Decimal         @map("weight_delta_kg") @db.Decimal(12, 3)
  valueDeltaKes Decimal         @default(0) @map("value_delta_kes") @db.Decimal(14, 2)
  reason        String
  createdBy     String          @map("created_by") @db.Uuid
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("corrections")
}

model StockAdjustment {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  weightDeltaKg Decimal  @map("weight_delta_kg") @db.Decimal(12, 3)
  reason        String
  createdBy     String   @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ScrapCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("stock_adjustments")
}

model LedgerEvent {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  eventType     String   @map("event_type")
  payload       Json     @default("{}")
  actorId       String?  @map("actor_id") @db.Uuid
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("ledger_events")
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String?  @map("tenant_id") @db.Uuid
  userId       String?  @map("user_id") @db.Uuid
  action       String
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id") @db.Uuid
  metadataJson Json     @default("{}") @map("metadata_json")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
