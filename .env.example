# Database — Docker maps Postgres to host port 5434 (see infra/docker-compose.yml)
DATABASE_URL=postgresql://yardflow:yardflow@127.0.0.1:5434/yardflow?schema=public

# API
PORT=3001
NODE_ENV=development
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=http://localhost:3000

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── M-Pesa / Daraja ──────────────────────────────────────────────────────────
# NEVER commit real secrets. Store actual values in your team password manager.
# See docs/MPESA_INTEGRATION_RULES.md for full setup guide.

DARAJA_ENV=sandbox
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke

# Daraja OAuth credentials — from your Daraja app card at developer.safaricom.co.ke
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=

# STK Push (Paybill collection)
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=
DARAJA_TRANSACTION_TYPE=CustomerPayBillOnline

# Callback routing — must be a public HTTPS URL reachable by Safaricom
# For local dev: use Cloudflare Tunnel (cloudflared tunnel --url http://localhost:3001)
# Example: DARAJA_CALLBACK_BASE_URL=https://yardflow-dev.trycloudflare.com/v1
DARAJA_CALLBACK_BASE_URL=

# Sandbox test phone (Safaricom test number for STK Push simulator)
DARAJA_TEST_PHONE=254708374149

# B2C supplier payouts — leave empty until R8.4
DARAJA_B2C_SHORTCODE=
DARAJA_INITIATOR_NAME=
DARAJA_SECURITY_CREDENTIAL=
